      "cell_type": "code",
      "source": [
        "import re\n",
        "import numpy as np\n",
        "import pandas as pd\n",
        "\n",
        "\n",
        "def literal_absolute_perfect_engine_classifier_v4(row):\n",
        "    # 文字列の標準化\n",
        "    engine_str = (\n",
        "        str(row[\"engine\"]).lower().strip() if pd.notna(row[\"engine\"]) else \"\"\n",
        "    )\n",
        "    model_str = (\n",
        "        str(row[\"model\"]).lower().strip() if pd.notna(row[\"model\"]) else \"\"\n",
        "    )\n",
        "\n",
        "    model_clean = (\n",
        "        model_str.replace(\" \", \"\")\n",
        "        .replace(\"-\", \"\")\n",
        "        .replace(\"/\", \"\")\n",
        "        .replace(\".\", \"\")\n",
        "    )\n",
        "    combined_text = model_clean + \" \" + engine_str\n",
        "\n",
        "    # 変数の初期化\n",
        "    displacement = np.nan\n",
        "    engine_type = \"Unknown\"\n",
        "\n",
        "    # ─── 【ステップ1】純電気自動車（BEV）の絶対・最優先隔離 ───\n",
        "    # テスラやリヴィアンなどのEVブランド、および明確なEVモデルはここで「Other, 0.0L」に確定\n",
        "    pure_ev_brands = [\"tesla\", \"rivian\", \"lucid\", \"polestar\"]\n",
        "    pure_ev_models = [\n",
        "        \"modely\",\n",
        "        \"model3\",\n",
        "        \"modelx\",\n",
        "        \"models\",\n",
        "        \"r1s\",\n",
        "        \"r1t\",\n",
        "        \"airgrand\",\n",
        "        \"airpure\",\n",
        "        \"mustangmache\",\n",
        "        \"f150lightning\",\n",
        "        \"etron\",\n",
        "        \"ev6\",\n",
        "        \"bolteuv\",\n",
        "        \"boltev\",\n",
        "        \"leaf\",\n",
        "        \"lyriq\",\n",
        "        \"konaev\",\n",
        "        \"id4\",\n",
        "        \"bz4x\",\n",
        "        \"egolf\",\n",
        "        \"c40recharge\",\n",
        "        \"500e\",\n",
        "        \"eqs450\",\n",
        "        \"ioniq5\",\n",
        "        \"ioniq6\",\n",
        "    ]\n",
        "\n",
        "    is_pure_bev = False\n",
        "\n",
        "    # 1. ブランド名やモデル名での判定\n",
        "    if any(b in model_clean for b in pure_ev_brands) or any(\n",
        "        m in model_clean for m in pure_ev_models\n",
        "    ):\n",
        "        is_pure_bev = True\n",
        "    # 2. エンジン表記からの判定（HVやガソリン等の混在がない純粋なモーター）\n",
        "    elif \"electric motor\" in engine_str and not any(\n",
        "        x in combined_text for x in [\"hybrid\", \"phev\", \"plugin\", \"gas\"]\n",
        "    ):\n",
        "        is_pure_bev = True\n",
        "    elif (\n",
        "        \"electric\" in engine_str or \"battery electric\" in engine_str\n",
        "    ) and not any(x in combined_text for x in [\"hybrid\", \"phev\", \"plugin\"]):\n",
        "        if not \"solara\" in model_clean:  # Solaraの誤判定防止\n",
        "            is_pure_bev = True\n",
        "\n",
        "    # ※ただし、プラグインハイブリッド(PHEV)やレンジエクステンダー(i3等)はエンジンを持つのでEV枠から除外\n",
        "    if any(\n",
        "        x in combined_text\n",
        "        for x in [\n",
        "            \"phev\",\n",
        "            \"plugin\",\n",
        "            \"hybrid\",\n",
        "            \"recharge\",\n",
        "            \"grandtouring\",\n",
        "            \"i3\",\n",
        "            \"revero\",\n",
        "        ]\n",
        "    ):\n",
        "        # ボルボ等の純EV（C40等）以外の、ハイブリッド系は除外\n",
        "        if not any(ext in model_clean for ext in [\"c40recharge\", \"egolf\"]):\n",
        "            is_pure_bev = False\n",
        "\n",
        "    # 純EV判定が確定したら、ここで完全に終了（Other, 0.0）\n",
        "    if is_pure_bev:\n",
        "        return pd.Series([\"Other\", 0.0])\n",
        "\n",
        "    # ─── 【ステップ2】確定ガソリン車 / ハイブリッド車の事前マッピング ───\n",
        "    if \"solara\" in model_clean:\n",
        "        engine_type, displacement = \"V6\", 3.3\n",
        "    elif \"ftype\" in model_clean:\n",
        "        engine_type, displacement = \"V6\", 3.0\n",
        "    elif \"macan\" in model_clean:\n",
        "        engine_type, displacement = \"V6\", 3.0\n",
        "    elif \"450h\" in model_clean:\n",
        "        engine_type, displacement = \"V6\", 3.5\n",
        "    elif \"55\" in model_clean and any(\n",
        "        x in model_clean for x in [\"a8\", \"a6\", \"q8\", \"a7\", \"q7\"]\n",
        "    ):\n",
        "        engine_type, displacement = \"V6\", 3.0\n",
        "    elif (\n",
        "        \"40i\" in model_clean\n",
        "        or \"440i\" in model_clean\n",
        "        or \"340i\" in model_clean\n",
        "        or \"m40i\" in model_clean\n",
        "        or \"x7xdrive40i\" in model_clean\n",
        "    ):\n",
        "        engine_type, displacement = \"V6\", 3.0\n",
        "    elif \"53\" in model_clean and \"amg\" in model_clean:\n",
        "        engine_type, displacement = \"V6\", 3.0\n",
        "    elif (\n",
        "        \"63\" in model_clean and \"amg\" in model_clean\n",
        "    ) or \"g63\" in model_clean:\n",
        "        engine_type, displacement = \"V8\", 4.0\n",
        "    elif (\n",
        "        \"580\" in model_clean\n",
        "        or \"560\" in model_clean\n",
        "        or \"550\" in model_clean\n",
        "        or \"flyingspur\" in model_clean\n",
        "    ):\n",
        "        engine_type, displacement = \"V8\", 4.0\n",
        "    elif \"392\" in model_clean or \"srt\" in model_clean:\n",
        "        engine_type, displacement = \"V8\", 6.2\n",
        "    elif \"huracan\" in model_clean or \"r8\" in model_clean:\n",
        "        engine_type, displacement = \"V10\", 5.2\n",
        "    elif \"aventador\" in model_clean:\n",
        "        engine_type, displacement = \"V12/W16\", 6.5\n",
        "    elif \"i3\" in model_clean:\n",
        "        engine_type, displacement = \"I3\", 0.65\n",
        "    elif \"revero\" in model_clean:\n",
        "        engine_type, displacement = \"I4\", 2.0\n",
        "    elif any(\n",
        "        x in model_clean\n",
        "        for x in [\n",
        "            \"prius\",\n",
        "            \"ct200h\",\n",
        "            \"rav4\",\n",
        "            \"evoque\",\n",
        "            \"q3\",\n",
        "            \"x3xdrive30i\",\n",
        "            \"ilx\",\n",
        "            \"kicks\",\n",
        "            \"camaro\",\n",
        "        ]\n",
        "    ):\n",
        "        engine_type, displacement = \"I4\", 2.0\n",
        "\n",
        "    # ─── 【ステップ3】テキストからの排気量（リッター数）の自動抽出 ───\n",
        "    if engine_type == \"Unknown\" and pd.isna(displacement):\n",
        "        match_l = re.search(r\"(\\d+\\.\\d+|\\d+)\\s*(l|t|liter|litres)\", engine_str)\n",
        "        if match_l:\n",
        "            try:\n",
        "                displacement = float(match_l.group(1))\n",
        "            except ValueError:\n",
        "                pass\n",
        "\n",
        "    if engine_type == \"Unknown\" and (\n",
        "        pd.isna(displacement) or displacement > 10.0\n",
        "    ):\n",
        "        match_num = re.search(r\"\\b(\\d+\\.\\d+)\\b\", engine_str + \" \" + model_str)\n",
        "        if match_num:\n",
        "            try:\n",
        "                val = float(match_num.group(1))\n",
        "                if 0.5 <= val <= 8.5:\n",
        "                    displacement = val\n",
        "            except ValueError:\n",
        "                pass\n",
        "\n",
        "    # ─── 【ステップ4】気筒数（エンジンタイプ）の分類 ───\n",
        "    if engine_type == \"Unknown\":\n",
        "        if any(x in combined_text for x in [\"12cyl\", \"v12\", \"w16\", \"16cyl\"]):\n",
        "            engine_type = \"V12/W16\"\n",
        "        elif any(x in combined_text for x in [\"10cyl\", \"v10\"]):\n",
        "            engine_type = \"V10\"\n",
        "        elif any(x in combined_text for x in [\"8cyl\", \"v8\"]):\n",
        "            engine_type = \"V8\"\n",
        "        elif any(\n",
        "            x in combined_text\n",
        "            for x in [\"6cyl\", \"v6\", \"i6\", \"inline6\", \"flat6\", \"h6\", \"mhev\"]\n",
        "        ):\n",
        "            engine_type = \"V6\"\n",
        "        elif any(x in combined_text for x in [\"5cyl\", \"i5\"]):\n",
        "            engine_type = \"I5\"\n",
        "        elif any(\n",
        "            x in combined_text\n",
        "            for x in [\"4cyl\", \"i4\", \"inline4\", \"hybrid\", \"phev\", \"plugin\"]\n",
        "        ):\n",
        "            engine_type = \"I4\"\n",
        "        elif any(x in combined_text for x in [\"3cyl\", \"i3\"]):\n",
        "            engine_type = \"I3\"\n",
        "        elif \"rotary\" in combined_text or \"rx8\" in model_clean:\n",
        "            engine_type = \"Rotary\"\n",
        "\n",
        "    # ─── 【ステップ5】最終防衛ライン ───\n",
        "    if engine_type == \"Unknown\":\n",
        "        if pd.notna(displacement) and displacement > 0:\n",
        "            if displacement >= 6.0:\n",
        "                engine_type = \"V12/W16\"\n",
        "            elif displacement >= 4.0:\n",
        "                engine_type = \"V8\"\n",
        "            elif displacement >= 2.6:\n",
        "                engine_type = \"V6\"\n",
        "            elif displacement >= 1.3:\n",
        "                engine_type = \"I4\"\n",
        "            else:\n",
        "                engine_type = \"I3\"\n",
        "        else:\n",
        "            if any(\n",
        "                t in model_clean\n",
        "                for t in [\n",
        "                    \"f150\",\n",
        "                    \"1500\",\n",
        "                    \"sierra\",\n",
        "                    \"silverado\",\n",
        "                    \"tundra\",\n",
        "                    \"ram\",\n",
        "                    \"expedition\",\n",
        "                    \"tahoe\",\n",
        "                    \"armada\",\n",
        "                    \"wagoneer\",\n",
        "                ]\n",
        "            ):\n",
        "                engine_type, displacement = \"V6\", 3.5\n",
        "            else:\n",
        "                engine_type, displacement = \"I4\", 2.0\n",
        "\n",
        "    return pd.Series([engine_type, displacement])\n",
        "\n",
        "\n",
        "# データフレームへの一括適用\n",
        "marged_df[[\"engine_type_clean\", \"displacement_l\"]] = marged_df.apply(\n",
        "    literal_absolute_perfect_engine_classifier_v4, axis=1\n",
        ")\n",
        "\n",
        "# 📊 結果の最終確認\n",
        "df8 = marged_df[marged_df[\"engine_type_clean\"] == \"Other\"]\n",
        "print(df8[\"model\"].value_counts())"
